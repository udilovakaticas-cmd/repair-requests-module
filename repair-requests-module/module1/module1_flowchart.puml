@startuml
title Модуль 1: Учет заявок (ГОСТ 19.701)

skinparam conditionStyle inside
skinparam Style strictuml

start
:Авторизация пользователя;
if (Данные верны?) then (да)
  :Определение роли;
  
  if (Роль == "Оператор") then (да)
    :Регистрация новой заявки;
    :Присвоение ID;
    :Назначение мастера;
  else if (Роль == "Мастер") then (да)
    :Выбор заявки из списка;
    :Изменение статуса;
    :Добавление комментария;
  else if (Роль == "Менеджер") then (да)
    :Запрос данных из списка;
    :Расчет статистики;
    :Формирование отчета;
  endif

else (нет)
  :Окно ошибки: "Неверный логин";
  stop
endif

:Обновление отображения данных;
stop
@enduml